@startuml

title User Login Authentication Sequence Diagram

actor "User (Any)" as User

participant "Frontend (Website)" as FE
participant "Apache\n(HTTP Server)" as Apache

box "Laravel Application" #LightGreen
  participant "Middleware" as MW
  participant "Controller" as C
  participant "SAML Authentication Service" as S
  participant "Role Service" as RS
  participant "Eloquent ORM" as ORM
end box

note right of User
IMPORTANT: This sequence assumes normal system operation. If a failure
occurs at any layer, the system returns an error message
and prompts the user to retry. 
end note

participant "UPR Identity Provider\n(UPRM Auth Server)" as IdP
database "MariaDB Database" as DB
loop
User -> FE: Click Login (UPRM) option
activate FE

FE -> Apache: Send login request
activate Apache
Apache -> MW: Forward request
deactivate Apache

activate MW
MW -> C: Pass login request
deactivate MW

activate C
C -> S: Request authentication
deactivate C

activate S
S -> IdP: SAML Authentication Request
activate IdP

IdP --> User: Show UPR login page
activate User

User -> IdP: Enter UPRM credentials
deactivate User

IdP -> IdP: Verify credentials
IdP --> S: SAML Assertion (authenticated user)
deactivate IdP

S -> S: Validate SAML assertion


alt User Registered


    S --> C: Authenticated user 
activate C
 activate ORM
ORM -> DB: Query user / role data
activate DB


  C -> RS: Check user role
  activate RS
RS-> ORM: Request Role
  deactivate RS

deactivate ORM
    DB --> C: User role result
deactivate DB
    C --> MW: Login success response
    deactivate C

    activate MW
    MW --> Apache: Authenticated response
    deactivate MW

    activate Apache
    Apache --> FE: Return authenticated response
    deactivate Apache

    activate User
    FE --> User: Redirect to role dashboard
    deactivate User

else User not registered
    S --> C: Access denied
    deactivate S
    activate C
    C --> MW: Denial response
    deactivate C

    activate MW
    MW --> Apache: Access denied response
    deactivate MW

    activate Apache
    Apache --> FE: Return denial response
    deactivate Apache

    activate User
    FE --> User: Show denial message
    deactivate User
end

deactivate FE
end

@enduml