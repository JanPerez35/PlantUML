@startuml

title Facility Admin Control Sequence Diagram with Exceptions

actor "Facility Admin" as Admin

participant "Frontend (Web Portal)" as FE
participant "Apache\n(HTTP Server)" as Apache

box "Laravel Application" #LightGreen
  participant "Middleware" as MW
  participant "Controller" as C
  participant "Facility Cost Service" as Service
  participant "Eloquent ORM" as ORM
end box

participant "EventFlow API" as EventFlow
database "MariaDB Database" as DB

note left of DB
It is assumed the Facility Admin is
authenticated/authorized unless an exception occurs.
end note

== Adding Event ==

Admin -> FE: Enter event cost details (description, amount, event date)
activate Admin
activate FE
activate Apache
activate MW
activate C
activate Service
activate ORM
activate EventFlow
activate DB

FE -> Apache: POST /addEvent

alt Route exists
    Apache -> MW: Forward HTTP request to Laravel middleware
else Route not found
    Apache --> FE: 404 Not Found
    FE --> Admin: Display "Add event route not found" error
end

alt Valid + Authorized
    MW -> C: Pass validated and authorized event creation request
else Validation/Auth error
    MW --> FE: 422 Unprocessable Entity / 401 Unauthorized / 403 Forbidden
    FE --> Admin: Display validation or authorization error
end

C -> Service: addEvent(eventCostData)
Service -> ORM: createFacilityEvent(description, amount, eventDate)
ORM -> DB: INSERT INTO facility_events (description, amount, event_date, created_by) VALUES (...)

alt DB insert success
    DB --> ORM: Insert successful
    ORM --> Service: Facility event persisted
    Service --> C: Event cost record created successfully
    C --> FE: Return event creation success response
    FE --> Admin: Show "Event added successfully"
else DB insert failure
    DB --> ORM: Insert failed / SQL exception
    ORM --> Service: Facility event persistence failed
    Service --> C: 500 Internal Server Error
    C --> FE: Return "Unable to save event cost record" error response
    FE --> Admin: Display system error while creating event
end


== Deleting Event ==

Admin -> FE: Select event record and click "Delete"
FE -> Apache: DELETE /deleteEvent/{eventId}

alt Route exists
    Apache -> MW: Forward HTTP request to Laravel middleware
else Route not found
    Apache --> FE: 404 Not Found
    FE --> Admin: Display "Delete event route not found" error
end

alt Valid + Authorized
    MW -> C: Pass validated and authorized deletion request
else Validation/Auth error
    MW --> FE: 422 Unprocessable Entity / 401 Unauthorized / 403 Forbidden
    FE --> Admin: Display validation or authorization error
end

C -> Service: deleteEvent(eventId)
Service -> ORM: deleteFacilityEventById(eventId)
ORM -> DB: DELETE FROM facility_events WHERE event_id = ?

alt DB delete success
    DB --> ORM: Delete successful
    ORM --> Service: Facility event removed
    Service --> C: Event cost record deleted successfully
    C --> FE: Return deletion success response
    FE --> Admin: Show "Cost deleted successfully"
else DB delete failure
    DB --> ORM: Delete failed / SQL exception
    ORM --> Service: Facility event deletion failed
    Service --> C: 500 Internal Server Error
    C --> FE: Return "Unable to delete event cost record" error response
    FE --> Admin: Display system error while deleting event
end


== Pulling Data from EventFlow API ==

Admin -> FE: Request synchronized EventFlow data
FE -> Apache: GET /pullEventFlowData

alt Route exists
    Apache -> MW: Forward HTTP request to Laravel middleware
else Route not found
    Apache --> FE: 404 Not Found
    FE --> Admin: Display "EventFlow sync route not found" error
end

alt Valid + Authorized
    MW -> C: Pass validated and authorized external data sync request
else Validation/Auth error
    MW --> FE: 422 Unprocessable Entity / 401 Unauthorized / 403 Forbidden
    FE --> Admin: Display validation or authorization error
end

C -> Service: fetchEventFlowData()
Service -> EventFlow: GET /events or relevant external dataset

alt API request success
    EventFlow --> Service: Return external event and cost data
    Service -> ORM: saveImportedEventFlowData(apiResponseData)
    ORM -> DB: INSERT INTO imported_eventflow_data (...)

    alt DB insert success
        DB --> ORM: Import insert successful
        ORM --> Service: Imported EventFlow data persisted
        Service --> C: Return synchronized EventFlow dataset
        C --> FE: Return pulled EventFlow data
        FE --> Admin: Show imported event data
    else DB insert failure
        DB --> ORM: Insert failed / SQL exception
        ORM --> Service: Imported data persistence failed
        Service --> C: 500 Internal Server Error
        C --> FE: Return "Unable to store imported EventFlow data" error response
        FE --> Admin: Display system error during data import
    end

else API unavailable / request failed
    EventFlow --> Service: HTTP timeout / 5xx error / connection failure
    Service --> C: External EventFlow service unavailable
    C --> FE: 503 Service Unavailable
    FE --> Admin: Display "EventFlow service is currently unavailable" message
end


== Downloading Report ==

Admin -> FE: Download facility cost report
FE -> Apache: GET /downloadReport

alt Route exists
    Apache -> MW: Forward HTTP request to Laravel middleware
else Route not found
    Apache --> FE: 404 Not Found
    FE --> Admin: Display "Download report route not found" error
end

alt Valid + Authorized
    MW -> C: Pass validated and authorized report download request
else Validation/Auth error
    MW --> FE: 422 Unprocessable Entity / 401 Unauthorized / 403 Forbidden
    FE --> Admin: Display validation or authorization error
end

C -> Service: getReport(reportType, dateRange)
Service -> ORM: getFacilityCostReportData(reportFilters)
ORM -> DB: SELECT * FROM facility_events_and_imported_data WHERE report_filters_apply

alt DB query success
    DB --> ORM: Report dataset returned
    ORM --> Service: Report data loaded successfully
    Service --> C: Return generated report file (CSV/PDF)
    C --> FE: Stream report download response
    FE --> Admin: File downloaded successfully
else DB query failure
    DB --> ORM: Query failed / SQL exception
    ORM --> Service: Report data retrieval failed
    Service --> C: 500 Internal Server Error
    C --> FE: Return "Unable to generate facility cost report" error response
    FE --> Admin: Display system error during report download
end

@enduml