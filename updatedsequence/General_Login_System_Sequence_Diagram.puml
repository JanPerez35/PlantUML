@startuml

title User Login Authentication Sequence Diagram with Exceptions

actor "User (Any)" as User

participant "Frontend (Website)" as FE
participant "Apache\n(HTTP Server)" as Apache

box "Laravel Application" #LightGreen
  participant "Middleware" as MW
  participant "Controller" as C
  participant "SAML Authentication Service" as S
  participant "Role Service" as RS
  participant "Eloquent ORM" as ORM
end box

participant "UPR Identity Provider\n(UPRM Auth Server)" as IdP
database "MariaDB Database" as DB


loop Login attempts

User -> FE: Click "Login with UPRM" button
activate User
activate FE
activate Apache
activate MW
activate C
activate S
activate RS
activate ORM
activate IdP
activate DB

FE -> Apache: GET /auth/saml/login

alt Route exists
    Apache -> MW: Forward HTTP authentication request
else Route not found
    Apache --> FE: 404 Not Found
    FE --> User: Display "SAML login route not found" error
end

alt Request valid
    MW -> C: Pass validated login request
else Validation / middleware error
    MW --> FE: 400 Bad Request / 419 CSRF Token Mismatch / 403 Forbidden
    FE --> User: Display login request or middleware validation error
end

C -> S: redirectToIdentityProvider()
S -> IdP: Send SAML authentication request

alt IdP available
    IdP --> User: Display UPRM login form
    User -> IdP: Submit institutional username and password
    IdP -> IdP: Validate credentials against identity store

    alt Credentials valid
        IdP --> S: Return SAML assertion for authenticated user
        S -> S: validateSamlAssertion(assertionPayload)

        alt Assertion valid
            S --> C: Return authenticated user identity payload
            C -> ORM: getUserByEmailOrInstitutionalId(userIdentifier)
            ORM -> DB: SELECT id, email, role, auth_type, banned_at FROM users WHERE email = ? OR institutional_id = ?

            alt User record found
                DB --> ORM: User account and role data
                ORM --> C: User lookup result
                C -> RS: resolveUserRole(userId)
                RS -> ORM: getRoleByUserId(userId)

                alt Role lookup success
                    ORM --> RS: Role record returned
                    RS --> C: Authorized role resolution result
                    C --> MW: Return authenticated session response
                    MW --> Apache: Attach session/cookie and redirect response
                    Apache --> FE: Return authenticated redirect response
                    FE --> User: Redirect to assigned role dashboard

                else Role lookup failure
                    ORM --> RS: Role query failed / no role mapping found
                    RS --> C: Role resolution service error
                    C --> FE: 500 Internal Server Error
                    FE --> User: Display "Unable to determine user role" system error
                end

            else User not registered
                DB --> ORM: Empty result set
                ORM --> C: No matching local user account found
                C --> MW: Return access denial response
                MW --> Apache: Deny authenticated login attempt
                Apache --> FE: Return denial response
                FE --> User: Show "Authenticated user is not registered in MAIKINE" message
            end

        else Assertion invalid
            S --> C: SAML assertion validation failed
            C --> FE: 401 Unauthorized
            FE --> User: Show "Invalid or expired SAML assertion" authentication error
        end

    else Invalid credentials
        IdP --> S: Authentication rejected by identity provider
        S --> C: External login denied
        C --> FE: 401 Unauthorized
        FE --> User: Show "Invalid UPRM credentials" message
    end

else IdP unavailable
    IdP --> S: Identity provider timeout / connection failure / 5xx error
    S --> C: External authentication service unavailable
    C --> FE: 503 Service Unavailable
    FE --> User: Show "UPRM authentication service is currently unavailable" message
end

end

@enduml