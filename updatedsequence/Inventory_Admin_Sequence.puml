@startuml

title Inventory Admin Sequence Diagram with Exceptions

actor "Inventory Admin" as Admin
participant "Frontend Website" as Frontend
participant "Apache\n(HTTP Server)" as Apache

box "Laravel Application" #LightGreen
  participant "Middleware" as MW
  participant "Controller" as C
  participant "Inventory Service" as Service
  participant "Eloquent ORM" as ORM
end box

database "MariaDB Database" as DB

note right of Admin
Inventory Admin can perform
regular inventory user viewing actions,
such as browsing and checking inventory.

This diagram only shows
additional administrative actions.
end note

note left of DB
It is assumed the Inventory Admin is
authenticated/authorized unless an exception occurs.
end note


== Update Inventory (Add / Delete / Update Item) ==

Admin -> Frontend: Submit add/delete/edit inventory item action
activate Admin
activate Frontend
activate Apache
activate MW
activate C
activate Service
activate ORM
activate DB

Frontend -> Apache: POST /admin/items/update

alt Route exists
    Apache -> MW: Forward HTTP inventory update request
else Route not found
    Apache --> Frontend: 404 Not Found
    Frontend --> Admin: Display "Inventory update route not found" error
end

alt Valid + Authorized
    MW -> C: Pass validated and authorized inventory update request
else Validation/Auth error
    MW --> Frontend: 422 Unprocessable Entity / 401 Unauthorized / 403 Forbidden
    Frontend --> Admin: Display validation or authorization error
end

C -> Service: updateInventory(itemId, actionType, itemData)
Service -> ORM: editInventoryItem(itemData) or createInventoryItem(itemData) or deleteInventoryItemById(itemId)
ORM -> DB: INSERT INTO inventory_items (...) OR DELETE FROM inventory_items WHERE item_id = ?

alt DB update success
    DB --> ORM: Insert/delete/update operation successful
    ORM --> Service: Inventory update persisted
    Service --> C: Inventory modification completed successfully
    C --> Frontend: Return inventory update success response
    Frontend --> Admin: Display inventory update result
else DB update failure
    DB --> ORM: Insert/delete/update failed / SQL exception
    ORM --> Service: Inventory update persistence failed
    Service --> C: 500 Internal Server Error
    C --> Frontend: Return "Unable to update inventory item" error response
    Frontend --> Admin: Display system error while updating inventory
end


== Cancel Borrow of Special Request ==

Admin -> Frontend: Select borrow or special request to cancel
Frontend -> Apache: POST /admin/cancelRequest

alt Route exists
    Apache -> MW: Forward HTTP cancellation request
else Route not found
    Apache --> Frontend: 404 Not Found
    Frontend --> Admin: Display "Cancel request route not found" error
end

alt Valid + Authorized
    MW -> C: Pass validated and authorized cancellation request
else Validation/Auth error
    MW --> Frontend: 422 Unprocessable Entity / 401 Unauthorized / 403 Forbidden
    Frontend --> Admin: Display validation or authorization error
end

C -> Service: cancelRequest(requestId, requestType)
Service -> ORM: updateRequestStatusById(requestId, "Cancelled")
ORM -> DB: UPDATE borrow_requests OR special_requests SET status = 'Cancelled' WHERE request_id = ?

alt DB update success
    DB --> ORM: Status update successful
    ORM --> Service: Request cancellation persisted
    Service --> C: Request cancelled successfully
    C --> Frontend: Return cancellation success response
    Frontend --> Admin: Display cancellation confirmation
else DB update failure
    DB --> ORM: Update failed / SQL exception
    ORM --> Service: Request status update failed
    Service --> C: 500 Internal Server Error
    C --> Frontend: Return "Unable to cancel selected request" error response
    Frontend --> Admin: Display system error while cancelling request
end


== View and Download Inventory Statistics ==

Admin -> Frontend: Request inventory statistics report
Frontend -> Apache: GET /admin/statistics

alt Route exists
    Apache -> MW: Forward HTTP statistics request
else Route not found
    Apache --> Frontend: 404 Not Found
    Frontend --> Admin: Display "Inventory statistics route not found" error
end

alt Valid + Authorized
    MW -> C: Pass validated and authorized statistics request
else Validation/Auth error
    MW --> Frontend: 422 Unprocessable Entity / 401 Unauthorized / 403 Forbidden
    Frontend --> Admin: Display validation or authorization error
end

C -> Service: generateStatistics(reportType, dateRange)
Service -> ORM: getInventoryUsageStatistics(reportFilters)
ORM -> DB: SELECT inventory usage metrics, borrow counts, and availability summaries FROM inventory-related tables

alt DB query success
    DB --> ORM: Inventory statistics dataset
    ORM --> Service: Statistics data loaded successfully
    Service --> C: Generated inventory statistics report
    C --> Frontend: Return report data / downloadable file
    Frontend --> Admin: Display or download inventory statistics report
else DB query failure
    DB --> ORM: Query failed / SQL exception
    ORM --> Service: Inventory statistics retrieval failed
    Service --> C: 500 Internal Server Error
    C --> Frontend: Return "Unable to generate inventory statistics report" error response
    Frontend --> Admin: Display system error while loading statistics
end

@enduml