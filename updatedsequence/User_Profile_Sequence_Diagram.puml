@startuml

title User Profile Sequence Diagram with Exceptions

actor User

participant "Frontend (Website)" as FE
participant "Apache\n(HTTP Server)" as Apache

box "Laravel Application" #LightGreen
  participant "Middleware" as MW
  participant "Controller" as C
  participant "Inventory Service" as Service
  participant "Messaging Service" as MessageService
  participant "Eloquent ORM" as ORM
end box

database "MariaDB Database" as DB

note right of User
It is assumed the User is
authenticated/authorized unless an exception occurs.
end note


== View User Posts ==

User -> FE: Click "My Posts"
activate User
activate FE
activate Apache
activate MW
activate C
activate Service
activate MessageService
activate ORM
activate DB

FE -> Apache: GET /user/posts

alt Route exists
    Apache -> MW: Forward HTTP user posts request
else Route not found
    Apache --> FE: 404 Not Found
    FE --> User: Display "User posts route not found" error
end

alt Valid + Authorized
    MW -> C: Pass validated and authorized posts request
else Validation/Auth error
    MW --> FE: 401 Unauthorized / 403 Forbidden / 422 Unprocessable Entity
    FE --> User: Display validation or authorization error
end

C -> Service: getUserPosts(userId, filters, pagination)
Service -> ORM: getMarketplacePostsByUserId(userId)
ORM -> DB: SELECT * FROM marketplace_posts WHERE user_id = ? ORDER BY created_at DESC

alt DB query success
    DB --> ORM: User post result set
    ORM --> Service: User post collection returned
    Service --> C: Marketplace posts for authenticated user
    C --> FE: Return user posts response
    FE --> User: Show personal post list
else DB query failure
    DB --> ORM: Query failed / SQL exception
    ORM --> Service: User post retrieval failed
    Service --> C: 500 Internal Server Error
    C --> FE: Return "Unable to load user posts" error response
    FE --> User: Display system error while loading posts
end


== Delete a Post ==

User -> FE: Click "Delete" on selected post
FE -> Apache: DELETE /post/{postId}

alt Route exists
    Apache -> MW: Forward HTTP delete post request
else Route not found
    Apache --> FE: 404 Not Found
    FE --> User: Display "Delete post route not found" error
end

alt Valid + Authorized
    MW -> C: Pass validated and authorized delete request
else Validation/Auth error
    MW --> FE: 401 Unauthorized / 403 Forbidden / 422 Unprocessable Entity
    FE --> User: Display validation or authorization error
end

C -> Service: deletePost(postId, userId)
Service -> ORM: getPostOwnerById(postId)
ORM -> DB: SELECT user_id FROM marketplace_posts WHERE post_id = ?

alt Ownership query success
    DB --> ORM: Post ownership result
    ORM --> Service: Ownership lookup returned

    alt User is owner
        Service -> ORM: deleteMarketplacePostById(postId)
        ORM -> DB: DELETE FROM marketplace_posts WHERE post_id = ?

        alt DB delete success
            DB --> ORM: Delete successful
            ORM --> Service: Marketplace post removed
            Service --> C: Post deletion confirmed
            C --> FE: Return deletion success response
            FE --> User: Display "Post deleted successfully"
        else DB delete failure
            DB --> ORM: Delete failed / SQL exception
            ORM --> Service: Post deletion failed
            Service --> C: 500 Internal Server Error
            C --> FE: Return "Unable to delete selected post" error response
            FE --> User: Display system error while deleting post
        end

    else User is not owner
        Service --> C: Post ownership validation failed
        C --> FE: 403 Forbidden
        FE --> User: Show "You can only delete your own posts" error
    end

else Ownership query failure
    DB --> ORM: Query failed / SQL exception
    ORM --> Service: Ownership verification failed
    Service --> C: 500 Internal Server Error
    C --> FE: Return "Unable to verify post ownership" error response
    FE --> User: Display system error while validating ownership
end


== Check Messages ==

User -> FE: Open "Messages"
FE -> Apache: GET /user/messages

alt Route exists
    Apache -> MW: Forward HTTP user messages request
else Route not found
    Apache --> FE: 404 Not Found
    FE --> User: Display "User messages route not found" error
end

alt Valid + Authorized
    MW -> C: Pass validated and authorized messages request
else Validation/Auth error
    MW --> FE: 401 Unauthorized / 403 Forbidden / 422 Unprocessable Entity
    FE --> User: Display validation or authorization error
end

C -> MessageService: getUserMessages(userId, filters, pagination)
MessageService -> ORM: getMessagesByParticipantId(userId)
ORM -> DB: SELECT * FROM messages WHERE sender_id = ? OR recipient_id = ? ORDER BY created_at DESC

alt DB query success
    DB --> ORM: User message result set
    ORM --> MessageService: Message collection returned
    MessageService --> C: User conversation messages
    C --> FE: Return user messages response
    FE --> User: Show message list
else DB query failure
    DB --> ORM: Query failed / SQL exception
    ORM --> MessageService: Message retrieval failed
    MessageService --> C: 500 Internal Server Error
    C --> FE: Return "Unable to load user messages" error response
    FE --> User: Display system error while loading messages
end


== View Borrow/Lend Requests ==

User -> FE: Open "My Requests"
FE -> Apache: GET /user/requests

alt Route exists
    Apache -> MW: Forward HTTP user request history request
else Route not found
    Apache --> FE: 404 Not Found
    FE --> User: Display "User requests route not found" error
end

alt Valid + Authorized
    MW -> C: Pass validated and authorized request history request
else Validation/Auth error
    MW --> FE: 401 Unauthorized / 403 Forbidden / 422 Unprocessable Entity
    FE --> User: Display validation or authorization error
end

C -> Service: getUserRequests(userId, requestType, filters)
Service -> ORM: getBorrowAndLendRequestsByUserId(userId)
ORM -> DB: SELECT * FROM borrow_requests WHERE user_id = ? UNION SELECT * FROM lend_requests WHERE user_id = ?

alt DB query success
    DB --> ORM: User request history result set
    ORM --> Service: Borrow/lend request collection returned
    Service --> C: User request history
    C --> FE: Return request status response
    FE --> User: Show borrow/lend request statuses
else DB query failure
    DB --> ORM: Query failed / SQL exception
    ORM --> Service: User request retrieval failed
    Service --> C: 500 Internal Server Error
    C --> FE: Return "Unable to load user requests" error response
    FE --> User: Display system error while loading requests
end

@enduml