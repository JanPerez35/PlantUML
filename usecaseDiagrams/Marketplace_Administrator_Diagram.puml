@startuml
left to right direction
skinparam packageStyle rectangle

actor "Marketplace Administrator" as MarketplaceAdmin

rectangle MAIKINE {

  usecase "Login" as UC_Login
  usecase "Logout" as UC_Logout

  usecase "Browse\nMarketplace" as UC_Browse
  usecase "Browse Market Management" as UC_Mana
  usecase "Search users" as UC_SearchUsers
  usecase "Add user listing" as UC_AddListing
  usecase "Delete user\nlisting" as UC_DeleteUserListing
  usecase "Chat with user" as UC_Chat
  usecase "Report a post" as UC_Report
  usecase "Ban user" as UC_BanUser
  usecase "Review reported posts" as UC_View
  usecase "Filter posts" as UC_Filter
  usecase "View user profile" as UC_ViewProfile
  usecase "View reviews" as UC_ViewReview
  usecase "Resolve report" as UC_Resolve
  usecase "View reported post\n reviews/ratings" as UC_Research
  usecase "Delete user\npost" as UC_DeleteUserPost
  

  note bottom of (UC_Logout)
  Log out is an extend of all other views and usecases
  end note
}

MarketplaceAdmin -- UC_Login
UC_Login <.. UC_Logout :<<extend>>
UC_Login <.. UC_Browse :<<extend>>
UC_Login <.. UC_Mana :<<extend>>
UC_Login <.. UC_SearchUsers :<<extend>>

UC_Mana <.. UC_View :<<extend>>
UC_Mana <.. UC_BanUser :<<exntend>>

UC_View <.. UC_ViewProfile :<<extend>>
UC_View <..UC_Resolve:<<extend>>
UC_View <.. UC_DeleteUserListing :<<extend>>
UC_View <.. UC_Research : <<extend>>


UC_Browse <.. UC_Chat :<<extend>>

UC_Browse <.. UC_Filter :<<extend>>
UC_Browse <.. UC_AddListing :<<extend>>
UC_Browse <.. UC_ViewReview :<<extend>>
UC_Browse <.. UC_Report :<<extend>>
UC_Browse <.. UC_DeleteUserPost :<<extend>>

UC_Logout -down[hidden]-> UC_Browse



@enduml