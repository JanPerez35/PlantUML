@startuml
left to right direction
skinparam packageStyle rectangle

actor User

rectangle MAIKINE {

 
  usecase "Log-in" as UC_Login
  usecase "Logout" as UC_Logout

 
  usecase "Browse Marketplace" as UC_BrowseMP


  usecase "Search items" as UC_Search
  usecase "Filter search" as UC_Filter
  usecase "View a listing" as UC_Listing
  usecase "Chat with seller" as UC_Chat
  usecase "Rate account" as UC_Rate
  usecase "Report account" as UC_Report
  usecase "Receive unread chat email\n after 15 min" as UC_EmailChat
  usecase "List equipment for sale" as UC_List
  usecase "Delete own listing" as UC_DeleteList

  
  usecase "Browse Department Kinventory" as UC_BrowseIN
 
  usecase "Search for equipment" as UC_EquipSearch
  usecase "Filter equipment" as UC_EquipFilter

 
  usecase "View own listing/sales" as UC_View
  usecase "View own chats" as UC_ViewChat
  usecase "View own borrow requests" as UC_BorrowRequest
  usecase "View own reviews/ratings" as UC_Review

  usecase "Read FAQ" as UC_ReadFAQ
  usecase "Read contact information" as UC_ReadContact

  usecase "Request sport equipment for lending" as UC_Request
  usecase "Receive equipment response email" as UC_EmailResponse
}

User --> UC_Login
User --> UC_Logout
UC_Login <.. UC_BrowseMP : <<extend>>
UC_Login <.. UC_List : <<extend>>
UC_Login <.. UC_DeleteList : <<extend>>
UC_Login <.. UC_BrowseIN : <<extend>>
UC_Login <.. UC_View : <<extend>>
UC_Login <.. UC_ViewChat : <<extend>>
UC_Login <.. UC_BorrowRequest : <<extend>>
UC_Login <.. UC_ReadContact : <<extend>>
UC_Login <.. UC_Review : <<extend>>
UC_Login <.. UC_ReadFAQ : <<extend>>



UC_Search ..> UC_BrowseMP : <<extend>>
UC_Filter ..> UC_BrowseMP : <<extend>>
UC_Listing ..> UC_BrowseMP : <<extend>>

UC_Chat ..> UC_Listing : <<extend>>
UC_Rate ..> UC_Listing : <<extend>>
UC_Report ..> UC_Listing : <<extend>>
UC_EmailChat ..> UC_Chat : <<extend>>

UC_EquipSearch ..> UC_BrowseIN : <<extend>>
UC_EquipFilter ..> UC_BrowseIN : <<extend>>
UC_EmailResponse ..> UC_Request : <<extend>>
 UC_BrowseIN <.. UC_Request : <<extend>>


UC_BrowseMP -[hidden]-> UC_Search
UC_Search -[hidden]-> UC_Filter
UC_Filter -[hidden]-> UC_Listing
UC_Listing -[hidden]-> UC_Chat
UC_Chat -[hidden]-> UC_Rate
UC_Rate -[hidden]-> UC_Report
UC_Report -[hidden]-> UC_EmailChat

UC_BrowseIN -[hidden]-> UC_EquipSearch
UC_EquipSearch -[hidden]-> UC_EquipFilter
UC_EquipFilter -[hidden]-> UC_Request
UC_Request -[hidden]-> UC_EmailResponse

note left of UC_Logout
Available from any
authenticated state
end note


@enduml